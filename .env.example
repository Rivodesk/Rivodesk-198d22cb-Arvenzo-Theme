# Shopify Storefront API
# Haal dit op via: Shopify Admin → Settings → Apps → Develop apps → Storefront API
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=jouw-winkel.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_ACCESS_TOKEN=jouw_storefront_access_token

# Optioneel: voor server-side calls (veiliger)
SHOPIFY_STOREFRONT_ACCESS_TOKEN=jouw_storefront_access_token
