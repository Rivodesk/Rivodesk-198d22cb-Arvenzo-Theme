# Shopify Storefront API – server-side only (NOOIT blootgesteld aan de browser)
# Haal dit op via: Shopify Admin → Settings → Apps → Develop apps → Storefront API
SHOPIFY_STORE_DOMAIN=jouw-winkel.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=jouw_storefront_access_token

# Resend Email API
# Registreer op https://resend.com en haal hier je API key op
RESEND_API_KEY=re_test_placeholder
